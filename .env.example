# Copie este arquivo para .env e preencha com suas credenciais do DagsHub
# NUNCA commite o arquivo .env no Git!

# Seu nome de usuário no DagsHub
DAGSHUB_USER=seu_usuario_aqui

# Nome do repositório criado no DagsHub
DAGSHUB_REPO=sentimento-app

# Token de acesso: dagshub.com → User Settings → Tokens → New Token
DAGSHUB_TOKEN=seu_token_aqui
