# Copie este arquivo para .env e preencha com suas credenciais do DagsHub
# NUNCA commite o arquivo .env no Git!

# URL do Projeto no Supabase
SUPABASE_URL=sua_url_aqui

# Token de acesso: app.supabase.com → Project Settings → API Keys → Legacy anon → chave anon/public
SUPABASE_KEY=sua_key_aqui

# Seu nome de usuário no DagsHub
DAGSHUB_USER=seu_usuario_aqui

# Nome do repositório criado no DagsHub
DAGSHUB_REPO=seu_repositorio_aqui

# Token de acesso: dagshub.com → User Settings → Tokens → New Token
DAGSHUB_TOKEN=seu_token_aqui

# Credenciais Kaggle (Account -> API -> Create New Token)
# Use os valores do arquivo kaggle.json baixado no Kaggle
KAGGLE_USERNAME=seu_usuario_kaggle
KAGGLE_KEY=sua_chave_kaggle
